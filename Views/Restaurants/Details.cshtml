@model FoodOrderingApp.Models.Restaurant

@{
    ViewBag.Title = "Restaurant Details - " + Model.Name;
}

<h2>@Model.Name</h2>
<p>@Model.Description</p>
<p>Location: @Model.Location</p>

<h3>Menu Items</h3>
@if (Model.MenuItems.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Add to Cart</th>
                <th>Item</th>
                <th>Price</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.MenuItems)
            {
                <tr>
                    <td>
                        <input type="checkbox" class="addToCartCheckbox" data-item-id="@item.ItemId" data-item-name="@item.Name" data-item-price="@(item.Price.HasValue ? item.Price.Value : 0)" data-restaurant-id="@Model.RestaurantId" />
                    </td>
                    <td>@item.Name</td>
                    <td>@(item.Price.HasValue ? item.Price.Value.ToString("C") : "N/A")</td>
                </tr>
            }
        </tbody>
    </table>
    <p>
        @Html.ActionLink("View Cart", "Cart", "Restaurants", null, new { @class = "btn btn-info" })
    </p>
}
else
{
    <p>This restaurant does not have any menu items yet.</p>
}

@section scripts {
    <script>
        $(document).ready(function () {
            $('.addToCartCheckbox').change(function () {
                var isChecked = $(this).prop('checked');
                var itemId = $(this).data('item-id');
                var itemName = $(this).data('item-name');
                var itemPrice = $(this).data('item-price');
                var restaurantId = $(this).data('restaurant-id');

                if (isChecked) {
                    // Make an AJAX call to add the item to the cart
                    $.ajax({
                        url: '@Url.Action("AddToCartAjax", "Restaurants")',
                        type: 'POST',
                        data: { itemId: itemId, itemName: itemName, price: itemPrice, restaurantId: restaurantId },
                        success: function (response) {
                            // Optionally, update a cart count or display a message
                            console.log('Item added to cart:', response);
                        },
                        error: function (error) {
                            console.error('Error adding item to cart:', error);
                            // Optionally, uncheck the box or display an error message
                            $(this).prop('checked', false);
                        }
                    });
                } else {
                    // Optionally, handle removing the item if you want that functionality
                    // with a checkbox (more complex with quantity).
                    console.log('Item unchecked (no immediate removal implemented)');
                }
            });
        });
    </script>
}